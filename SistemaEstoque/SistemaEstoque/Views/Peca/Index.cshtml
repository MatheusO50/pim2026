@model List<Peca>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Lista de Peças</h2>
        <a class="btn btn-primary" href="/Peca/Create">+ Nova Peça</a>
    </div>

    <table class="table table-dark table-striped table-hover">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Preço</th>
                <th style="width: 150px;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Nome</td>
                    <td>R$ @p.Preco.ToString("F2")</td>
                    <td>
                        <a class="btn btn-sm btn-warning" href="/Peca/Edit/@p.Id">Editar</a>
                        <a class="btn btn-sm btn-danger" href="/Peca/Delete/@p.Id"
                           onclick="return confirm('Tem certeza?')">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>